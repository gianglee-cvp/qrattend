{
  "version": 2,
  "builds": [
    {
      "src": "backend/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "src": "/login",
      "dest": "/frontend/login.html"
    },
    {
      "src": "/login/admin",
      "dest": "/frontend/login_admin.html"
    },
    {
      "src": "/login/teacher",
      "dest": "/frontend/login_teacher.html"
    },
    {
      "src": "/login/student",
      "dest": "/frontend/login_student.html"
    },
    {
      "src": "/admin",
      "dest": "/frontend/admin.html"
    },
    {
      "src": "/teacher",
      "dest": "/frontend/teacher.html"
    },
    {
      "src": "/student",
      "dest": "/frontend/student.html"
    },
    {
      "src": "/student-portal",
      "dest": "/frontend/student_portal.html"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|svg|ico|json))",
      "dest": "/frontend/$1"
    },
    {
      "src": "/",
      "dest": "/frontend/login.html"
    },
    {
      "src": "/(.*)",
      "dest": "/backend/index.js"
    }
  ]
}
